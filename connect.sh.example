remote_api_op() {
  local op="${1:-}"
  shift || true

  if [ -z "$op" ]; then
    echo "Usage: ./GameServer/connect.sh remote-api-op <operation> [--key=value ...]"
    exit 1
  fi

  local quoted_op quoted_args
  quoted_op="$(printf '%q' "$op")"
  quoted_args=""
  for arg in "$@"; do
    quoted_args+=" $(printf '%q' "$arg")"
  done

  ssh_runner_env_script <<EOF
set -e
cd "\$REMOTE_REPO_ROOT"
docker compose --env-file "\$REMOTE_ENV_FILE" -f GameServer/docker/compose.yml exec -T nest-api npm run api:ops -- --op=$quoted_op$quoted_args
EOF
}

#################################
# MAIN
#################################

case "${1:-}" in
  tryconfig) tryconfig ;;
  setupdev) setupdev ;;
  init) init ;;
  status) status ;;
  security) security ;;
  resources) resources ;;
  update) update ;;
  release-upgrade) release_upgrade ;;
  sync) sync_remote ;;
  sync-force) sync_remote_force ;;
  remote-env-push) remote_env_push ;;
  remote-env-validate) remote_env_validate ;;
  remote-drift) remote_drift ;;
  remote-status) remote_status ;;
  remote-realtime-check) remote_realtime_check ;;
  remote-mobile-firestore-audit) remote_mobile_firestore_audit ;;
  remote-prod-precheck) remote_prod_precheck ;;
  remote-code-ready) remote_code_ready ;;
  remote-deploy-ready) remote_deploy_ready ;;
  dev-tools-adv) remote_dev_tools_adv ;;
  remote-install-make) remote_install_make ;;
  docker-upgrade) remote_docker_upgrade ;;
  docker-fix) remote_docker_fix ;;
  remote-up) remote_up ;;
  remote-down) remote_down ;;
  remote-restart) remote_restart ;;
  remote-logs) remote_logs ;;
  remote-web-logs) remote_web_logs ;;
  remote-ps) remote_ps ;;
  remote-health) remote_health ;;
  remote-web-shell) remote_web_shell ;;
  remote-web-smoke) remote_web_smoke ;;
  remote-web-wallboard-smoke) remote_web_wallboard_smoke ;;
  remote-ws-usage) remote_ws_usage "${2:-30}" "${3:-20}" ;;
  remote-web-auth-debug) remote_web_auth_debug ;;
  remote-web-config-check) remote_web_config_check ;;
  remote-web-rebuild-nocache) remote_web_rebuild_nocache ;;
  remote-web-login-check) remote_web_login_check ;;
  lazydocker-install) remote_lazydocker_install ;;
  lazydocker) remote_lazydocker ;;
  remote-shell-api) remote_shell_api ;;
  remote-shell-mongo) remote_shell_mongo ;;
  remote-shell-postgres) remote_shell_postgres ;;
  remote-shell-redis) remote_shell_redis ;;
  remote-migrate-snapshot) remote_migrate_snapshot ;;
  remote-migrate-dry-run) remote_migrate_dry_run ;;
  remote-migrate-run) remote_migrate_run ;;
  remote-migrate-verify) remote_migrate_verify ;;
  remote-migrate-report) remote_migrate_report ;;
