remote_dev_tools_adv() {
  ssh_runner_script <<'EOF'
set -e

if [ -z "${SUDO_PASSWORD:-}" ]; then
  echo "❌ Missing SUDO_PASSWORD in remote session"
  exit 1
fi

sudo_cmd() {
  printf '%s\n' "$SUDO_PASSWORD" | sudo -S -p '' "$@"
}

if ! sudo_cmd -v >/dev/null 2>&1; then
  echo "❌ sudo authentication failed for RUNNER_USER with provided SUDO_PASSWORD"
  exit 1
fi

export DEBIAN_FRONTEND=noninteractive

base_pkgs=(
  ca-certificates
  curl
  git
  make
  jq
  unzip
  zip
  rsync
  tmux
  ripgrep
  fzf
  tree
  ncdu
  lsof
  dnsutils
  net-tools
)
optional_pkgs=(
  bat
  btop
  htop
  yq
  httpie
  gh
)

sudo_cmd apt-get update
sudo_cmd apt-get install -y "${base_pkgs[@]}"

for pkg in "${optional_pkgs[@]}"; do
  if ! sudo_cmd apt-get install -y "$pkg"; then
    echo "⚠️ Optional package failed: $pkg (continuing)"
  fi
done

if command -v batcat >/dev/null 2>&1 && ! command -v bat >/dev/null 2>&1; then
  sudo_cmd ln -sf "$(command -v batcat)" /usr/local/bin/bat
fi

# Keep lazydocker install aligned with upstream installer used in this repo.
curl -fsSL https://raw.githubusercontent.com/jesseduffield/lazydocker/master/scripts/install_update_linux.sh | bash --
if command -v lazydocker >/dev/null 2>&1; then
  lazy_bin="$(command -v lazydocker)"
  if [ "$lazy_bin" != "/usr/local/bin/lazydocker" ]; then
    sudo_cmd install -m 0755 "$lazy_bin" /usr/local/bin/lazydocker
  fi
fi

echo "✅ dev-tools-adv complete"
echo "--- versions ---"
for cmd in git docker jq yq rg fzf bat make tmux lazydocker gh; do
  if command -v "$cmd" >/dev/null 2>&1; then
    case "$cmd" in
      docker) "$cmd" --version | head -n 1 ;;
      lazydocker) "$cmd" --version | head -n 1 ;;
      *) "$cmd" --version 2>/dev/null | head -n 1 || true ;;
    esac
  else
    echo "$cmd: not installed"
  fi
done
EOF
}
remote_install_make() {
  ssh_runner_script <<'EOF'
set -e

if [ -z "${SUDO_PASSWORD:-}" ]; then
  echo "❌ Missing SUDO_PASSWORD in remote session"
  exit 1
fi

sudo_cmd() {
  printf '%s\n' "$SUDO_PASSWORD" | sudo -S -p '' "$@"
}

if ! sudo_cmd -v >/dev/null 2>&1; then
  echo "❌ sudo authentication failed for RUNNER_USER with provided SUDO_PASSWORD"
  exit 1
fi

export DEBIAN_FRONTEND=noninteractive
sudo_cmd apt-get update
sudo_cmd apt-get install -y make
make --version | head -n 1
echo "✅ make installed on remote host."
EOF
}
remote_docker_upgrade() {
  ssh_runner_script <<'EOF'
set -e

if [ -z "${SUDO_PASSWORD:-}" ]; then
  echo "❌ Missing SUDO_PASSWORD in remote session"
  exit 1
fi

sudo_cmd() {
  printf '%s\n' "$SUDO_PASSWORD" | sudo -S -p '' "$@"
}

if ! sudo_cmd -v >/dev/null 2>&1; then
  echo "❌ sudo authentication failed for RUNNER_USER with provided SUDO_PASSWORD"
  exit 1
fi

echo "ℹ️ Upgrading Docker Engine and Compose plugin..."
install_script="$(mktemp)"
trap 'rm -f "$install_script"' EXIT
curl -fsSL https://get.docker.com -o "$install_script"
sudo_cmd sh "$install_script"

sudo_cmd systemctl enable docker
sudo_cmd systemctl restart docker
sudo_cmd usermod -aG docker "$USER"

# Remove stale API pinning that breaks modern daemon negotiation.
for shell_file in "$HOME/.zshrc" "$HOME/.bashrc" "$HOME/.profile"; do
  [ -f "$shell_file" ] || continue
  sed -i '/^[[:space:]]*export[[:space:]]\+DOCKER_API_VERSION=/d' "$shell_file"
  sed -i '/^[[:space:]]*DOCKER_API_VERSION=/d' "$shell_file"
done

echo "✅ Docker upgrade complete"
docker --version
docker compose version
echo "DOCKER_API_VERSION runtime value: ${DOCKER_API_VERSION:-<unset>}"
echo "ℹ️ Reconnect SSH once so group/env cleanup fully applies, then re-run lazydocker."
EOF
}
remote_docker_fix() {
  ssh_runner_script <<EOF
set -e

if [ -z "\${SUDO_PASSWORD:-}" ]; then
  echo "❌ Missing SUDO_PASSWORD in remote session"
  exit 1
fi

sudo_cmd() {
  printf '%s\n' "\$SUDO_PASSWORD" | sudo -S -p '' "\$@"
}

if ! sudo_cmd -v >/dev/null 2>&1; then
  echo "❌ sudo authentication failed for RUNNER_USER with provided SUDO_PASSWORD"
  exit 1
fi

export DEBIAN_FRONTEND=noninteractive

if ! command -v docker >/dev/null 2>&1; then
  echo "ℹ️ Docker binary missing. Installing Docker engine..."
  install_script="\$(mktemp)"
  if ! curl -fsSL https://get.docker.com -o "\$install_script"; then
    rm -f "\$install_script"
    echo "⚠️ Failed to download get.docker.com install script."
  elif ! sudo_cmd sh "\$install_script"; then
    rm -f "\$install_script"
    echo "⚠️ get.docker.com install failed. Falling back to apt docker.io package."
    sudo_cmd apt-get update
    sudo_cmd apt-get install -y docker.io
  else
    rm -f "\$install_script"
  fi
fi

if ! command -v docker >/dev/null 2>&1; then
  echo "❌ Docker is still unavailable after repair attempts."
  exit 1
fi

sudo_cmd systemctl enable docker
sudo_cmd systemctl restart docker
sudo_cmd usermod -aG docker "$RUNNER_USER"

if ! docker compose version >/dev/null 2>&1; then
  echo "ℹ️ Docker Compose plugin missing. Installing user-scoped plugin..."
  mkdir -p ~/.docker/cli-plugins
  arch="\$(uname -m)"
  case "\$arch" in
    x86_64|amd64) compose_arch="x86_64" ;;
    aarch64|arm64) compose_arch="aarch64" ;;
    *)
      echo "❌ Unsupported architecture for Docker Compose plugin: \$arch"
      exit 1
      ;;
  esac
  curl -fsSL "https://github.com/docker/compose/releases/download/v2.25.0/docker-compose-linux-\$compose_arch" \
    -o ~/.docker/cli-plugins/docker-compose
  chmod +x ~/.docker/cli-plugins/docker-compose
fi

echo "✅ Docker repair complete"
docker --version
docker compose version
if groups "$RUNNER_USER" | grep -q '\bdocker\b'; then
  echo "✅ runner user is in docker group"
else
  echo "⚠️ runner user not in docker group yet"
fi
echo "ℹ️ If this is your first docker-group add, reconnect SSH once so group changes apply."
EOF
}
