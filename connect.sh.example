remote_ws_usage() {
  local minutes="${1:-30}"
  local limit="${2:-20}"
  if ! [[ "$minutes" =~ ^[0-9]+$ ]]; then
    echo "Usage: ./GameServer/connect.sh remote-ws-usage [minutes] [limit]"
    echo "minutes must be a positive integer."
    exit 1
  fi
  if ! [[ "$limit" =~ ^[0-9]+$ ]]; then
    echo "Usage: ./GameServer/connect.sh remote-ws-usage [minutes] [limit]"
    echo "limit must be a positive integer."
    exit 1
  fi

  ssh_runner_env_script <<EOF
set -e
cd "\$REMOTE_REPO_ROOT"
set -a
. "\$REMOTE_ENV_FILE"
set +a
docker compose --env-file "\$REMOTE_ENV_FILE" -f GameServer/docker/compose.yml exec -T \
  -e WS_MINUTES="$minutes" -e WS_LIMIT="$limit" \
  mongo mongosh --quiet -u "\$MONGO_USER" -p "\$MONGO_PASSWORD" --authenticationDatabase admin fastfingers --eval '
const minutes = Math.max(1, Number(process.env.WS_MINUTES || "30"));
const limit = Math.max(1, Number(process.env.WS_LIMIT || "20"));
const since = new Date(Date.now() - minutes * 60 * 1000);
const coll = db.getCollection("usage_ws_events");
printjson({
  window_minutes: minutes,
  total_last_window: coll.countDocuments({ ts: { \$gte: since } }),
  connect_last_window: coll.countDocuments({ event_type: "socket.connect", ts: { \$gte: since } }),
  sub_leaderboard_last_window: coll.countDocuments({ event_type: /subscribe\\.leaderboard/, ts: { \$gte: since } }),
  outbound_leaderboard_last_window: coll.countDocuments({ event_type: "leaderboard:update", direction: "outbound", ts: { \$gte: since } })
});
print("recent:");
coll
  .find({ ts: { \$gte: since } }, { _id: 0, event_type: 1, direction: 1, channel: 1, uid: 1, ts: 1 })
  .sort({ ts: -1 })
  .limit(limit)
  .forEach((x) => printjson(x));
'
EOF
}
remote_web_auth_debug() { remote_make gameserver-web-auth-debug; }
remote_web_config_check() { remote_make gameserver-web-config-check; }
remote_web_rebuild_nocache() {
  ssh_runner_env_script <<'EOF'
set -e
cd "$REMOTE_REPO_ROOT"
echo "remote cwd: $PWD"
echo "🔨 Rebuilding web image without cache..."
docker compose --env-file "$REMOTE_ENV_FILE" -f GameServer/docker/compose.yml build --no-cache web
echo "🚀 Restarting web service..."
# Avoid rare stale-name conflicts from interrupted compose restarts.
docker rm -f web >/dev/null 2>&1 || true
docker compose --env-file "$REMOTE_ENV_FILE" -f GameServer/docker/compose.yml up -d --force-recreate web
echo "📊 Web container status:"
docker compose --env-file "$REMOTE_ENV_FILE" -f GameServer/docker/compose.yml ps web
EOF
}
remote_web_login_check() {
  ssh_runner_env_script <<'EOF'
set -e
cd "$REMOTE_REPO_ROOT"
echo "remote cwd: $PWD"
page="$(curl -fsS http://127.0.0.1:3002/login || curl -fsS http://localhost:3002/login)"
if printf '%s' "$page" | rg -q "invalid_type|NEXT_PUBLIC_FIREBASE_API_KEY|NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN|NEXT_PUBLIC_FIREBASE_PROJECT_ID|NEXT_PUBLIC_FIREBASE_APP_ID"; then
  echo "❌ Login page still shows Firebase NEXT_PUBLIC env validation errors."
  exit 1
fi
if ! printf '%s' "$page" | rg -q "Fast Fingers Control Room"; then
  echo "❌ Login page copy is stale; expected 'Fast Fingers Control Room'."
  exit 1
fi
if printf '%s' "$page" | rg -q "Google-authenticated access for game operations|This console requires a Google Firebase account with staff role claim"; then
  echo "❌ Login page still contains legacy body copy."
  exit 1
fi
echo "✅ Login page check passed (copy + env wiring)."
EOF
}
remote_lazydocker_install() {
  ssh_runner_script <<EOF
set -e

if [ -z "\${SUDO_PASSWORD:-}" ]; then
  echo "❌ Missing SUDO_PASSWORD in remote session"
  exit 1
fi

sudo_cmd() {
  printf '%s\n' "\$SUDO_PASSWORD" | sudo -S -p '' "\$@"
}

if ! sudo_cmd -v >/dev/null 2>&1; then
  echo "❌ sudo authentication failed for RUNNER_USER with provided SUDO_PASSWORD"
  exit 1
fi

curl -fsSL https://raw.githubusercontent.com/jesseduffield/lazydocker/master/scripts/install_update_linux.sh | bash --

bin_path=""
if command -v lazydocker >/dev/null 2>&1; then
  bin_path="\$(command -v lazydocker)"
elif [ -x "\$HOME/.local/bin/lazydocker" ]; then
  bin_path="\$HOME/.local/bin/lazydocker"
elif [ -x "\$HOME/bin/lazydocker" ]; then
  bin_path="\$HOME/bin/lazydocker"
fi

if [ -z "\$bin_path" ]; then
  echo "❌ lazydocker install script finished, but binary was not found in PATH or common user bin paths."
  exit 1
fi

sudo_cmd install -m 0755 "\$bin_path" /usr/local/bin/lazydocker
echo "✅ lazydocker installed: \$(/usr/local/bin/lazydocker --version | head -n 1)"
EOF
}

remote_lazydocker() {
  local target
  target="$(runner_ssh_target)"
  ssh -t -p "$NEW_SSH_PORT" "$target" "if command -v lazydocker >/dev/null 2>&1; then api_version=\$(docker version --format '{{.Server.APIVersion}}' 2>/dev/null || true); if [ -z \"\$api_version\" ]; then api_version=1.53; fi; env DOCKER_API_VERSION=\"\$api_version\" lazydocker; else echo 'lazydocker not installed. Run ./GameServer/connect.sh lazydocker-install first.'; exit 1; fi"
}
